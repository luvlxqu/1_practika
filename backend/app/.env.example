# Safe Contact — пример конфигурации
# Скопируйте в backend/.env и заполните значениями
# НИКОГДА не коммитьте настоящий .env!

FLASK_APP=app.py
FLASK_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/safecontact
SECRET_KEY=change-me-to-random-string-64-chars
JWT_SECRET_KEY=change-me-to-another-random-string
LOGTO_CLIENT_ID=your-client-id
LOGTO_CLIENT_SECRET=your-client-secret
